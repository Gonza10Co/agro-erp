// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  passwordHash  String
  isActive      Boolean        @default(true)
  roleId        Int
  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  despachosAutorizados    Despacho[]
  incidenciasAutorizadas  IncidenciaCalidad[]
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenHash String
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

// ───────────────────────── Módulo 1: Catálogos + BOM ─────────────────────────

enum OrigenMaterial {
  COMPRADO
  FABRICADO
}

enum ClaseBom {
  DIRECTO_CURVA
  DIRECTO_FIJO
  INDIRECTO
}

enum ClaseConsumo {
  CURVA
  FIJO
}

enum AccionOverride {
  ADD
  REPLACE
  REMOVE
  SET_CONSUMO
}

enum TipoMarca {
  PROPIA
  MAQUILA
}

enum EstadoRequerimiento {
  CALCULADO
}

model UnidadMedida {
  id         Int        @id @default(autoincrement())
  codigo     String     @unique
  nombre     String
  materiales Material[]
}

model CategoriaMaterial {
  id         Int        @id @default(autoincrement())
  nombre     String     @unique
  materiales Material[]
}

model Material {
  id             Int               @id @default(autoincrement())
  codigo         String            @unique
  nombreCanonico String
  categoriaId    Int
  categoria      CategoriaMaterial @relation(fields: [categoriaId], references: [id])
  unidadMedidaId Int
  unidadMedida   UnidadMedida      @relation(fields: [unidadMedidaId], references: [id])
  origen         OrigenMaterial
  claseBom       ClaseBom
  activo         Boolean           @default(true)
  proveedorId    Int?
  proveedor      Proveedor?        @relation(fields: [proveedorId], references: [id])

  alias             MaterialAlias[]
  bomPropio         Bom?            @relation("BomDeMaterial")
  lineasComoInsumo  BomLinea[]      @relation("InsumoDeLinea")
  overridesObjetivo ReglaOverride[] @relation("MaterialObjetivo")
  overridesNuevo    ReglaOverride[] @relation("MaterialNuevo")
  inventario        InventarioMaterial?
  lineasReq         RequerimientoCompraLinea[]
}

model MaterialAlias {
  id          Int      @id @default(autoincrement())
  materialId  Int
  material    Material @relation(fields: [materialId], references: [id])
  textoLegacy String

  @@unique([materialId, textoLegacy])
}

model Talla {
  id    Int @id @default(autoincrement())
  valor Int @unique
  orden Int

  referenciasMin Referencia[]                @relation("TallaMin")
  referenciasMax Referencia[]                @relation("TallaMax")
  lineasTalla    BomLineaTalla[]
  overridesTalla ReglaOverrideTalla[]
  ocLineasTalla  OrdenCompraLineaTalla[]
  opLineasTalla  OrdenProduccionLineaTalla[]
  inventarioPT   InventarioPT[]
  lineasDespacho DespachoLinea[]
  pares          Par[]
}

model Referencia {
  id            Int     @id @default(autoincrement())
  codigo        String  @unique
  nombreInterno String
  tallaMinId    Int
  tallaMin      Talla   @relation("TallaMin", fields: [tallaMinId], references: [id])
  tallaMaxId    Int
  tallaMax      Talla   @relation("TallaMax", fields: [tallaMaxId], references: [id])
  activo        Boolean @default(true)

  bom                   Bom?
  overrides             ReglaOverride[]
  ejes                  ReferenciaEje[]
  marcas                ReferenciaMarca[]
  productosConfigurados ProductoConfigurado[]
}

model Bom {
  id           Int         @id @default(autoincrement())
  referenciaId Int?        @unique
  referencia   Referencia? @relation(fields: [referenciaId], references: [id])
  materialId   Int?        @unique
  material     Material?   @relation("BomDeMaterial", fields: [materialId], references: [id])
  version      Int         @default(1)
  vigenteDesde DateTime    @default(now())
  activo       Boolean     @default(true)

  lineas BomLinea[]
}

model BomLinea {
  id           Int          @id @default(autoincrement())
  bomId        Int
  bom          Bom          @relation(fields: [bomId], references: [id])
  materialId   Int
  material     Material     @relation("InsumoDeLinea", fields: [materialId], references: [id])
  claseConsumo ClaseConsumo
  consumoFijo  Decimal?
  mermaPct     Decimal?
  notas        String?

  lineasTalla BomLineaTalla[]

  @@index([bomId])
  @@index([materialId])
}

model BomLineaTalla {
  id         Int      @id @default(autoincrement())
  bomLineaId Int
  bomLinea   BomLinea @relation(fields: [bomLineaId], references: [id])
  tallaId    Int
  talla      Talla    @relation(fields: [tallaId], references: [id])
  consumo    Decimal

  @@unique([bomLineaId, tallaId])
}

model GrupoOpcion {
  id          Int     @id @default(autoincrement())
  codigo      String  @unique
  nombre      String
  obligatorio Boolean @default(false)
  orden       Int     @default(0)

  opciones Opcion[]
  ejes     ReferenciaEje[]
}

model Opcion {
  id            Int         @id @default(autoincrement())
  grupoOpcionId Int
  grupoOpcion   GrupoOpcion @relation(fields: [grupoOpcionId], references: [id])
  codigo        String
  nombre        String
  activo        Boolean     @default(true)

  overrides                   ReglaOverride[]
  productoConfiguradoOpciones ProductoConfiguradoOpcion[]

  @@unique([grupoOpcionId, codigo])
}

model Marca {
  id        Int       @id @default(autoincrement())
  codigo    String    @unique
  nombre    String
  tipo      TipoMarca
  clienteId Int?
  cliente   Cliente?  @relation(fields: [clienteId], references: [id])
  activo    Boolean   @default(true)

  overrides             ReglaOverride[]
  referenciaMarcas      ReferenciaMarca[]
  productosConfigurados ProductoConfigurado[]
}

model ReglaOverride {
  id                 Int            @id @default(autoincrement())
  referenciaId       Int
  referencia         Referencia     @relation(fields: [referenciaId], references: [id])
  opcionId           Int?
  opcion             Opcion?        @relation(fields: [opcionId], references: [id])
  marcaId            Int?
  marca              Marca?         @relation(fields: [marcaId], references: [id])
  accion             AccionOverride
  materialObjetivoId Int?
  materialObjetivo   Material?      @relation("MaterialObjetivo", fields: [materialObjetivoId], references: [id])
  materialNuevoId    Int?
  materialNuevo      Material?      @relation("MaterialNuevo", fields: [materialNuevoId], references: [id])
  consumoFijo        Decimal?
  heredaCurva        Boolean        @default(false)

  tallas ReglaOverrideTalla[]

  @@index([referenciaId])
  @@index([materialObjetivoId])
}

model ReglaOverrideTalla {
  id              Int           @id @default(autoincrement())
  reglaOverrideId Int
  reglaOverride   ReglaOverride @relation(fields: [reglaOverrideId], references: [id])
  tallaId         Int
  talla           Talla         @relation(fields: [tallaId], references: [id])
  consumo         Decimal

  @@unique([reglaOverrideId, tallaId])
}

model ReferenciaEje {
  id            Int         @id @default(autoincrement())
  referenciaId  Int
  referencia    Referencia  @relation(fields: [referenciaId], references: [id])
  grupoOpcionId Int
  grupoOpcion   GrupoOpcion @relation(fields: [grupoOpcionId], references: [id])
  obligatorio   Boolean     @default(false)

  @@unique([referenciaId, grupoOpcionId])
}

model ReferenciaMarca {
  id           Int        @id @default(autoincrement())
  referenciaId Int
  referencia   Referencia @relation(fields: [referenciaId], references: [id])
  marcaId      Int
  marca        Marca      @relation(fields: [marcaId], references: [id])

  @@unique([referenciaId, marcaId])
}

model ProductoConfigurado {
  id              Int        @id @default(autoincrement())
  codigo          String     @unique
  nombreComercial String
  referenciaId    Int
  referencia      Referencia @relation(fields: [referenciaId], references: [id])
  marcaId         Int
  marca           Marca      @relation(fields: [marcaId], references: [id])
  activo          Boolean    @default(true)

  opciones       ProductoConfiguradoOpcion[]
  lineasOC       OrdenCompraLinea[]
  lineasOP       OrdenProduccionLinea[]
  inventarioPT   InventarioPT[]
  lineasDespacho DespachoLinea[]
  pares          Par[]
}

model ProductoConfiguradoOpcion {
  id                    Int                 @id @default(autoincrement())
  productoConfiguradoId Int
  productoConfigurado   ProductoConfigurado @relation(fields: [productoConfiguradoId], references: [id])
  opcionId              Int
  opcion                Opcion              @relation(fields: [opcionId], references: [id])

  @@unique([productoConfiguradoId, opcionId])
}

// ───────────────────────── Módulo 2: Pedidos (OC → OP) ─────────────────────────

enum TipoCredito {
  CONTADO
  D30
  D60
  D90
}

enum EstadoCartera {
  AL_DIA
  VENCIDO
  BLOQUEADO
}

enum TipoBodega {
  PROPIA
  HERMANA
}

enum EstadoOC {
  BORRADOR
  CONFIRMADA
  EN_PRODUCCION
  CERRADA
  ANULADA
}

enum EstadoOP {
  CREADA
  AMARRADA
  EN_PRODUCCION
  DESPACHADA
  ANULADA
}

model Cliente {
  id            Int           @id @default(autoincrement())
  nit           String        @unique
  nombre        String
  ciudad        String?
  tipoCredito   TipoCredito   @default(CONTADO)
  cupo          Decimal?      @db.Decimal(14, 2)
  estadoCartera EstadoCartera @default(AL_DIA)
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  marcas        Marca[]
  ordenesCompra OrdenCompra[]
}

model Bodega {
  id        Int        @id @default(autoincrement())
  codigo    String     @unique
  nombre    String
  tipo      TipoBodega @default(PROPIA)
  prioridad Int        @default(100)
  activo    Boolean    @default(true)

  inventarioPT   InventarioPT[]
  lineasDespacho DespachoLinea[]
}

model OrdenCompra {
  id            Int      @id @default(autoincrement())
  consecutivo   Int      @unique
  ocCliente     String?
  clienteId     Int
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  fecha         DateTime @default(now())
  estado        EstadoOC @default(BORRADOR)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lineas          OrdenCompraLinea[]
  ordenProduccion OrdenProduccion?

  @@index([clienteId])
}

model OrdenCompraLinea {
  id                    Int                 @id @default(autoincrement())
  ocId                  Int
  oc                    OrdenCompra         @relation(fields: [ocId], references: [id])
  productoConfiguradoId Int
  productoConfigurado   ProductoConfigurado @relation(fields: [productoConfiguradoId], references: [id])

  tallas OrdenCompraLineaTalla[]

  @@index([ocId])
}

model OrdenCompraLineaTalla {
  id        Int              @id @default(autoincrement())
  ocLineaId Int
  ocLinea   OrdenCompraLinea @relation(fields: [ocLineaId], references: [id])
  tallaId   Int
  talla     Talla            @relation(fields: [tallaId], references: [id])
  cantidad  Int

  @@unique([ocLineaId, tallaId])
}

model InventarioPT {
  id                    Int                 @id @default(autoincrement())
  productoConfiguradoId Int
  productoConfigurado   ProductoConfigurado @relation(fields: [productoConfiguradoId], references: [id])
  tallaId               Int
  talla                 Talla               @relation(fields: [tallaId], references: [id])
  bodegaId              Int
  bodega                Bodega              @relation(fields: [bodegaId], references: [id])
  cantDisponible        Int                 @default(0)
  cantReservada         Int                 @default(0)

  reservas ReservaInventarioPT[]

  @@unique([productoConfiguradoId, tallaId, bodegaId])
  @@index([productoConfiguradoId, tallaId])
}

model OrdenProduccion {
  id          Int         @id @default(autoincrement())
  consecutivo Int         @unique
  ocId        Int         @unique
  oc          OrdenCompra @relation(fields: [ocId], references: [id])
  fecha       DateTime    @default(now())
  estado      EstadoOP    @default(CREADA)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lineas              OrdenProduccionLinea[]
  despacho            Despacho?
  requerimientos      RequerimientoCompra[]
  ordenesFabricacion  OrdenFabricacion[]
}

model OrdenProduccionLinea {
  id                    Int                 @id @default(autoincrement())
  opId                  Int
  op                    OrdenProduccion     @relation(fields: [opId], references: [id])
  productoConfiguradoId Int
  productoConfigurado   ProductoConfigurado @relation(fields: [productoConfiguradoId], references: [id])

  tallas OrdenProduccionLineaTalla[]

  @@index([opId])
}

model OrdenProduccionLineaTalla {
  id            Int                  @id @default(autoincrement())
  opLineaId     Int
  opLinea       OrdenProduccionLinea @relation(fields: [opLineaId], references: [id])
  tallaId       Int
  talla         Talla                @relation(fields: [tallaId], references: [id])
  cantPedida    Int
  cantAmarrada  Int                  @default(0)
  cantAProducir Int                  @default(0)

  reservas ReservaInventarioPT[]

  @@unique([opLineaId, tallaId])
}

model ReservaInventarioPT {
  id             Int                       @id @default(autoincrement())
  opLineaTallaId Int
  opLineaTalla   OrdenProduccionLineaTalla @relation(fields: [opLineaTallaId], references: [id])
  inventarioPTId Int
  inventarioPT   InventarioPT              @relation(fields: [inventarioPTId], references: [id])
  cantidad       Int

  @@index([opLineaTallaId])
  @@index([inventarioPTId])
}

// ───────────────────────── Módulo 3: Despacho ─────────────────────────

model Despacho {
  id                 Int             @id @default(autoincrement())
  consecutivo        Int             @unique
  opId               Int             @unique
  op                 OrdenProduccion @relation(fields: [opId], references: [id])
  fecha              DateTime        @default(now())
  autorizadoPorId    Int?
  autorizadoPor      User?           @relation(fields: [autorizadoPorId], references: [id])
  motivoAutorizacion String?
  createdAt          DateTime        @default(now())

  lineas DespachoLinea[]
}

model DespachoLinea {
  id                    Int                 @id @default(autoincrement())
  despachoId            Int
  despacho              Despacho            @relation(fields: [despachoId], references: [id])
  productoConfiguradoId Int
  productoConfigurado   ProductoConfigurado @relation(fields: [productoConfiguradoId], references: [id])
  tallaId               Int
  talla                 Talla               @relation(fields: [tallaId], references: [id])
  bodegaId              Int
  bodega                Bodega              @relation(fields: [bodegaId], references: [id])
  cantidad              Int

  @@index([despachoId])
}

// ───────────────────────── Módulo 4: Compras / Requerimientos ─────────────────────────

model Proveedor {
  id        Int      @id @default(autoincrement())
  nit       String   @unique
  nombre    String
  ciudad    String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materiales Material[]
  lineasReq  RequerimientoCompraLinea[]
}

model InventarioMaterial {
  id             Int      @id @default(autoincrement())
  materialId     Int      @unique
  material       Material @relation(fields: [materialId], references: [id])
  cantDisponible Decimal  @default(0) @db.Decimal(14, 4)
  updatedAt      DateTime @updatedAt
}

model RequerimientoCompra {
  id          Int                 @id @default(autoincrement())
  consecutivo Int                 @unique
  opId        Int
  op          OrdenProduccion     @relation(fields: [opId], references: [id])
  fecha       DateTime            @default(now())
  estado      EstadoRequerimiento @default(CALCULADO)
  createdAt   DateTime            @default(now())

  lineas RequerimientoCompraLinea[]

  @@index([opId])
}

model RequerimientoCompraLinea {
  id              Int                 @id @default(autoincrement())
  requerimientoId Int
  requerimiento   RequerimientoCompra @relation(fields: [requerimientoId], references: [id])
  materialId      Int
  material        Material            @relation(fields: [materialId], references: [id])
  proveedorId     Int?
  proveedor       Proveedor?          @relation(fields: [proveedorId], references: [id])
  cantNecesaria   Decimal             @db.Decimal(14, 4)
  cantDisponible  Decimal             @db.Decimal(14, 4)
  cantAComprar    Decimal             @db.Decimal(14, 4)

  @@index([requerimientoId])
}

// ───────────────────────── Módulo 5: MES / Fabricación ─────────────────────────

enum Celula {
  CORTE
  GUARNICION
  ALMACEN
  INYECCION
  PT
}

enum EstadoOF {
  ABIERTA
  EN_PROCESO
  TERMINADA
  ANULADA
}

enum EstadoPar {
  EN_PROCESO
  TERMINADO
  CANCELADO
  DADO_DE_BAJA
}

enum ClaseDano {
  BAJA      // daño total: acta + reposición automática
  REPROCESO // recuperable: solo registro
}

model OrdenFabricacion {
  id          Int             @id @default(autoincrement())
  consecutivo Int             @unique
  opId        Int
  op          OrdenProduccion @relation(fields: [opId], references: [id])
  fecha       DateTime        @default(now())
  estado      EstadoOF        @default(ABIERTA)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  pares Par[]

  @@index([opId])
}

model Par {
  id                    Int                 @id @default(autoincrement())
  codigo                String              @unique
  ofId                  Int
  of                    OrdenFabricacion    @relation(fields: [ofId], references: [id])
  productoConfiguradoId Int
  productoConfigurado   ProductoConfigurado @relation(fields: [productoConfiguradoId], references: [id])
  tallaId               Int
  talla                 Talla               @relation(fields: [tallaId], references: [id])
  celulaActual          Celula              @default(CORTE)
  estado                EstadoPar           @default(EN_PROCESO)
  reponeAParId          Int?    @unique     // si este par es una reposición, el par dado de baja que repone
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  reponeA     Par?  @relation("reposicion", fields: [reponeAParId], references: [id])
  repuestoPor Par?  @relation("reposicion")

  incidencias            IncidenciaCalidad[] @relation("incidencias")
  reposicionDeIncidencia IncidenciaCalidad?  @relation("reposicionDeIncidencia")

  eventos EventoTrazabilidad[]

  @@index([ofId])
  @@index([celulaActual])
}

model EventoTrazabilidad {
  id         Int      @id @default(autoincrement())
  parId      Int
  par        Par      @relation(fields: [parId], references: [id])
  celula     Celula
  operarioId Int
  operario   Operario @relation(fields: [operarioId], references: [id])
  maquinaId  Int
  maquina    Maquina  @relation(fields: [maquinaId], references: [id])
  timestamp  DateTime @default(now())

  @@index([parId])
  @@index([celula])
}

model Operario {
  id     Int     @id @default(autoincrement())
  nombre String
  celula Celula
  activo Boolean @default(true)

  eventos     EventoTrazabilidad[]
  incidencias IncidenciaCalidad[]
}

model Maquina {
  id     Int     @id @default(autoincrement())
  codigo String  @unique
  nombre String
  celula Celula
  activo Boolean @default(true)

  eventos EventoTrazabilidad[]
}

model TipoDano {
  id             Int       @id @default(autoincrement())
  codigo         String    @unique
  nombre         String
  celulaCausante Celula    // centro de costo al que se imputa
  clase          ClaseDano
  activo         Boolean   @default(true)

  incidencias IncidenciaCalidad[]
}

model IncidenciaCalidad {
  id              Int      @id @default(autoincrement())
  parId           Int
  par             Par      @relation("incidencias", fields: [parId], references: [id])
  tipoDanoId      Int
  tipoDano        TipoDano @relation(fields: [tipoDanoId], references: [id])
  celulaDeteccion Celula   // dónde se detectó (puede ≠ causante)
  operarioId      Int
  operario        Operario @relation(fields: [operarioId], references: [id])
  descripcion     String?  // obligatoria en BAJA (acta) — se valida en el service
  autorizadoPorId Int?     // solo BAJA: user GERENTE/ADMIN del JWT
  autorizadoPor   User?    @relation(fields: [autorizadoPorId], references: [id])
  parReposicionId Int?     @unique // solo BAJA: el par creado para reponer
  parReposicion   Par?     @relation("reposicionDeIncidencia", fields: [parReposicionId], references: [id])
  timestamp       DateTime @default(now())

  @@index([parId])
  @@index([tipoDanoId])
  @@index([operarioId])
}
